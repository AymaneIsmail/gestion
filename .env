###> gotenberg ###
GOTENBERG_URL=http://gotenberg:3000
###< gotenberg ###

###> anthropic ###
ANTHROPIC_API_KEY=
###< anthropic ###

###> openai ###
OPENAI_API_KEY=
AI_DESCRIPTION_ENABLED=true
AI_PROVIDER=openai
###< openai ###


###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_in_production_use_a_long_random_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: pgsql://user:password@host:port/dbname
DATABASE_URL="postgresql://gestion:gestion@database:5432/gestion?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
###< symfony/mailer ###

###> PostgreSQL ###
POSTGRES_DB=gestion
POSTGRES_USER=gestion
POSTGRES_PASSWORD=gestion
###< PostgreSQL ###

###> FrankenPHP ###
SERVER_NAME=localhost
###< FrankenPHP ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
