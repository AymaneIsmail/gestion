{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Catégories</h1>
        <p class="page-subtitle">{{ categories|length }} catégorie{{ categories|length != 1 ? 's' : '' }}</p>
    </div>
    <a href="{{ path('app_category_new') }}" class="btn btn--primary">+ Nouvelle catégorie</a>
</div>

{% if categories is empty %}
    <div class="empty-state">
        <div class="empty-state__icon">🏷️</div>
        <h2 class="empty-state__title">Aucune catégorie</h2>
        <p class="empty-state__description">Organisez vos produits en créant des catégories.</p>
        <a href="{{ path('app_category_new') }}" class="btn btn--primary">Créer une catégorie</a>
    </div>
{% else %}
    <div class="list-card">
        {% for category in categories %}
            <div class="list-card__item">
                <div class="list-card__info">
                    <span class="list-card__name">{{ category.name }}</span>
                    <span class="list-card__count">{{ category.products|length }} produit{{ category.products|length != 1 ? 's' : '' }}</span>
                </div>
                <div class="list-card__actions">
                    <div class="kebab-menu" data-controller="dropdown">
                        <button
                            type="button"
                            class="kebab-menu__trigger"
                            aria-label="Actions"
                            aria-haspopup="true"
                            data-action="click->dropdown#toggle"
                        >
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4z"/>
                            </svg>
                        </button>
                        <div class="kebab-menu__dropdown" data-dropdown-target="menu" role="menu">
                            <a href="{{ path('app_category_edit', {id: category.id}) }}"
                               class="kebab-menu__item"
                               role="menuitem">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                                </svg>
                                Modifier
                            </a>
                            <div class="kebab-menu__divider"></div>
                            <form method="post"
                                  action="{{ path('app_category_delete', {id: category.id}) }}"
                                  data-controller="confirm-delete">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-category-' ~ category.id) }}">
                                <button
                                    type="submit"
                                    class="kebab-menu__item kebab-menu__item--danger"
                                    role="menuitem"
                                    data-action="confirm-delete#confirm"
                                    data-confirm-delete-message-value="Êtes-vous sûr de vouloir supprimer cette catégorie ?"
                                >
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                    </svg>
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
