{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}
{% block body_class %}page-auth{% endblock %}

{% block content %}
<div class="auth-card">
    <div class="auth-card__header">
        <div class="auth-logo">📦</div>
        <h1 class="auth-card__title">Bon retour !</h1>
        <p class="auth-card__subtitle">Connectez-vous à EdentStock</p>
    </div>

    {% if error %}
        <div class="alert alert--error" style="margin-bottom:1.25rem">
            <div class="alert__body">
                <svg class="alert__icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
            </div>
        </div>
    {% endif %}

    <form method="post" style="display:flex;flex-direction:column;gap:1rem">
        <div class="form-group">
            <label for="username" class="form-label">Adresse e-mail</label>
            <input
                type="email"
                id="username"
                name="_username"
                value="{{ last_username }}"
                class="form-control"
                autocomplete="email"
                autofocus
                required
                placeholder="vous@exemple.fr"
            >
        </div>

        <div class="form-group">
            <label for="password" class="form-label">Mot de passe</label>
            <input
                type="password"
                id="password"
                name="_password"
                class="form-control"
                autocomplete="current-password"
                required
                placeholder="••••••••"
            >
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn btn--primary btn--full" style="margin-top:0.25rem">
            Se connecter →
        </button>
    </form>
</div>
{% endblock %}
