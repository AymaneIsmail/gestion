{% extends 'base.html.twig' %}

{% block title %}Tags{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Tags</h1>
        <p class="page-subtitle">{{ tags|length }} tag{{ tags|length != 1 ? 's' : '' }}</p>
    </div>
    <a href="{{ path('app_tag_new') }}" class="btn btn--primary">+ Nouveau tag</a>
</div>

{% if tags is empty %}
    <div class="empty-state">
        <div class="empty-state__icon">🔖</div>
        <h2 class="empty-state__title">Aucun tag</h2>
        <p class="empty-state__description">Les tags permettent de qualifier vos produits librement.</p>
        <a href="{{ path('app_tag_new') }}" class="btn btn--primary">Créer un tag</a>
    </div>
{% else %}
    <div class="list-card">
        {% for tag in tags %}
            <div class="list-card__item">
                <div class="list-card__info">
                    <span class="tag tag--lg">{{ tag.name }}</span>
                    <span class="list-card__count">{{ tag.products|length }} produit{{ tag.products|length != 1 ? 's' : '' }}</span>
                </div>
                <div class="list-card__actions">
                    <a href="{{ path('app_tag_edit', {id: tag.id}) }}" class="btn btn--secondary btn--sm">Modifier</a>
                    {{ include('partials/_delete_form.html.twig', {
                        action: path('app_tag_delete', {id: tag.id}),
                        token_id: 'delete-tag-' ~ tag.id,
                    }) }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
