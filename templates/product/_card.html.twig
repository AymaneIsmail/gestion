<div class="product-card">
    {% if product.images|length > 0 %}
        <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card__image-link">
            <img
                src="{{ path('app_image_serve', {id: product.images.first.id}) }}"
                alt="{{ product.name }}"
                class="product-card__image"
                loading="lazy"
            >
        </a>
    {% else %}
        <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card__image-link product-card__image-link--empty">
            <span class="product-card__no-image">📷</span>
        </a>
    {% endif %}

    <div class="product-card__body">
        <div class="product-card__meta">
            {% if product.category %}
                <span class="badge badge--category">{{ product.category.name }}</span>
            {% endif %}
            {% if product.reference %}
                <span class="badge badge--ref">{{ product.reference }}</span>
            {% endif %}
        </div>

        <h2 class="product-card__name">
            <a href="{{ path('app_product_show', {id: product.id}) }}">{{ product.name }}</a>
        </h2>

        <div class="product-card__prices">
            {% if product.price and product.price.sellingPriceCents %}
                <span class="product-card__price">
                    {{ (product.price.sellingPriceCents / 100)|number_format(2, ',', "\u{202F}") }} €
                </span>
            {% endif %}
            {% if product.price and product.price.purchasePriceCents %}
                <span class="product-card__purchase-price">
                    Achat : {{ (product.price.purchasePriceCents / 100)|number_format(2, ',', "\u{202F}") }} €
                </span>
            {% endif %}
        </div>

        <div class="product-card__stock {% if product.stockQuantity == 0 %}product-card__stock--empty{% endif %}">
            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                <path d="M1.5 2A1.5 1.5 0 000 3.5v2A1.5 1.5 0 001.5 7h13A1.5 1.5 0 0016 5.5v-2A1.5 1.5 0 0014.5 2h-13zM0 9.5A1.5 1.5 0 011.5 8h13A1.5 1.5 0 0116 9.5v2A1.5 1.5 0 0114.5 13h-13A1.5 1.5 0 010 11.5v-2z"/>
            </svg>
            {{ product.stockQuantity }} unité{{ product.stockQuantity != 1 ? 's' : '' }}
        </div>

        {% if product.tags|length > 0 %}
            <div class="product-card__tags">
                {% for tag in product.tags %}
                    <span class="tag">{{ tag.name }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="product-card__actions">
        <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card__actions-link">
            Voir le détail
        </a>
        <div class="kebab-menu kebab-menu--up" data-controller="dropdown">
            <button
                type="button"
                class="kebab-menu__trigger"
                aria-label="Actions"
                aria-haspopup="true"
                data-action="click->dropdown#toggle"
            >
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M10 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4z"/>
                </svg>
            </button>
            <div class="kebab-menu__dropdown" data-dropdown-target="menu" role="menu">
                <a href="{{ path('app_product_edit', {id: product.id}) }}"
                   class="kebab-menu__item"
                   role="menuitem">
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                    </svg>
                    Modifier
                </a>
                <a href="{{ path('app_product_export_pdf', {id: product.id}) }}"
                   class="kebab-menu__item"
                   target="_blank"
                   role="menuitem">
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd"/>
                    </svg>
                    Exporter PDF
                </a>
                <div class="kebab-menu__divider"></div>
                <form method="post"
                      action="{{ path('app_product_delete', {id: product.id}) }}"
                      data-controller="confirm-delete">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-product-' ~ product.id) }}">
                    <button
                        type="submit"
                        class="kebab-menu__item kebab-menu__item--danger"
                        role="menuitem"
                        data-action="confirm-delete#confirm"
                        data-confirm-delete-message-value="Êtes-vous sûr de vouloir supprimer ce produit ?"
                    >
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
