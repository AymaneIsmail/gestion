<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 12px;
        color: #1e293b;
        background: #fff;
        padding: 36px 40px;
    }

    /* ── Cover header ── */
    .cover {
        text-align: center;
        padding: 32px 0 28px;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 32px;
    }
    .cover__org { font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
    .cover__title { font-size: 28px; font-weight: 800; color: #0f172a; letter-spacing: -0.03em; margin-bottom: 6px; }
    .cover__meta { font-size: 11px; color: #94a3b8; }

    /* ── Product row ── */
    .product-row {
        display: flex;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid #f1f5f9;
        page-break-inside: avoid;
    }
    .product-row:last-of-type { border-bottom: none; }

    .product-row__image {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        border-radius: 8px;
        overflow: hidden;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: #cbd5e1;
    }
    .product-row__image img { width: 100%; height: 100%; object-fit: cover; }

    .product-row__body { flex: 1; }

    .product-row__top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
    }
    .product-row__name { font-size: 14px; font-weight: 700; color: #0f172a; }
    .product-row__ref { font-size: 11px; color: #94a3b8; margin-top: 1px; }

    .product-row__badges { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
    .badge {
        display: inline-block;
        padding: 2px 7px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 600;
    }
    .badge--category { background: #ede9fe; color: #5b21b6; }
    .badge--tag { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; }

    .product-row__prices {
        display: flex;
        gap: 20px;
    }
    .price-item__label { font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
    .price-item__value { font-size: 13px; font-weight: 700; }
    .price-item__value--selling { color: #4f46e5; }
    .price-item__value--positive { color: #16a34a; }
    .price-item__value--negative { color: #dc2626; }
    .price-item__value--stock { color: #0f172a; }

    /* ── Global totals ── */
    .totals {
        margin-top: 32px;
        background: #0f172a;
        border-radius: 12px;
        padding: 20px 24px;
        color: #fff;
        page-break-inside: avoid;
    }
    .totals__title {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.1em; color: #94a3b8; margin-bottom: 16px;
    }
    .totals__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .totals__item { background: rgba(255,255,255,0.06); border-radius: 8px; padding: 14px 16px; }
    .totals__label { font-size: 10px; color: #94a3b8; margin-bottom: 6px; font-weight: 500; }
    .totals__value { font-size: 16px; font-weight: 700; letter-spacing: -0.02em; color: #f1f5f9; }
    .totals__value--positive { color: #4ade80; }
    .totals__value--negative { color: #f87171; }
    .totals__sub { font-size: 10px; color: #475569; margin-top: 3px; }

    /* ── Footer ── */
    .footer {
        margin-top: 20px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #94a3b8;
    }
</style>
</head>
<body>

{# ── Cover ── #}
<div class="cover">
    <div class="cover__org">{{ organization.name }}</div>
    <div class="cover__title">Catalogue produits</div>
    <div class="cover__meta">
        {{ productsData|length }} produit{{ productsData|length > 1 ? 's' : '' }} — Généré le {{ generatedAt|date('d/m/Y à H:i') }}
    </div>
</div>

{# ── Calcul des totaux globaux ── #}
{% set globalStock = 0 %}
{% set globalPurchase = 0 %}
{% set globalSelling = 0 %}
{% set hasPurchase = false %}
{% set hasSelling = false %}

{% for item in productsData %}
    {% set p = item.product %}
    {% set globalStock = globalStock + p.stockQuantity %}
    {% if p.price and p.price.purchasePriceCents is not null %}
        {% set globalPurchase = globalPurchase + (p.stockQuantity * p.price.purchasePriceCents) %}
        {% set hasPurchase = true %}
    {% endif %}
    {% if p.price and p.price.sellingPriceCents is not null %}
        {% set globalSelling = globalSelling + (p.stockQuantity * p.price.sellingPriceCents) %}
        {% set hasSelling = true %}
    {% endif %}
{% endfor %}

{# ── Liste produits ── #}
{% for item in productsData %}
    {% set p = item.product %}
    <div class="product-row">
        <div class="product-row__image">
            {% if item.imageBase64 %}
                <img src="data:{{ item.imageMime }};base64,{{ item.imageBase64 }}" alt="{{ p.name }}">
            {% else %}
                📷
            {% endif %}
        </div>
        <div class="product-row__body">
            <div class="product-row__top">
                <div>
                    <div class="product-row__name">{{ p.name }}</div>
                    {% if p.reference %}<div class="product-row__ref">Réf. {{ p.reference }}</div>{% endif %}
                </div>
            </div>
            <div class="product-row__badges">
                {% if p.category %}<span class="badge badge--category">{{ p.category.name }}</span>{% endif %}
                {% for tag in p.tags %}<span class="badge badge--tag">{{ tag.name }}</span>{% endfor %}
            </div>
            <div class="product-row__prices">
                <div>
                    <div class="price-item__label">Stock</div>
                    <div class="price-item__value price-item__value--stock">{{ p.stockQuantity }} unité{{ p.stockQuantity > 1 ? 's' : '' }}</div>
                </div>
                {% if p.price and p.price.purchasePriceCents is not null %}
                <div>
                    <div class="price-item__label">Prix d'achat</div>
                    <div class="price-item__value">{{ (p.price.purchasePriceCents / 100)|number_format(2, ',', ' ') }} €</div>
                </div>
                {% endif %}
                {% if p.price and p.price.sellingPriceCents is not null %}
                <div>
                    <div class="price-item__label">Prix de vente</div>
                    <div class="price-item__value price-item__value--selling">{{ (p.price.sellingPriceCents / 100)|number_format(2, ',', ' ') }} €</div>
                </div>
                {% endif %}
                {% if p.price and p.price.purchasePriceCents is not null and p.price.sellingPriceCents is not null %}
                    {% set margin = p.price.sellingPriceCents - p.price.purchasePriceCents %}
                <div>
                    <div class="price-item__label">Marge unitaire</div>
                    <div class="price-item__value {{ margin >= 0 ? 'price-item__value--positive' : 'price-item__value--negative' }}">
                        {{ (margin / 100)|number_format(2, ',', ' ') }} €
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endfor %}

{# ── Totaux globaux ── #}
<div class="totals">
    <div class="totals__title">Récapitulatif global</div>
    <div class="totals__grid">
        <div class="totals__item">
            <div class="totals__label">Produits</div>
            <div class="totals__value">{{ productsData|length }}</div>
            <div class="totals__sub">références</div>
        </div>
        <div class="totals__item">
            <div class="totals__label">Stock total</div>
            <div class="totals__value">{{ globalStock }}</div>
            <div class="totals__sub">unités</div>
        </div>
        <div class="totals__item">
            <div class="totals__label">Valeur d'achat totale</div>
            {% if hasPurchase %}
                <div class="totals__value">{{ (globalPurchase / 100)|number_format(2, ',', ' ') }} €</div>
            {% else %}
                <div class="totals__value" style="color:#475569">—</div>
            {% endif %}
        </div>
        <div class="totals__item">
            <div class="totals__label">Revenu de vente potentiel</div>
            {% if hasSelling %}
                <div class="totals__value totals__value--positive">{{ (globalSelling / 100)|number_format(2, ',', ' ') }} €</div>
                {% if hasPurchase %}
                    {% set globalMargin = globalSelling - globalPurchase %}
                    <div class="totals__sub">Marge : {{ (globalMargin / 100)|number_format(2, ',', ' ') }} €</div>
                {% endif %}
            {% else %}
                <div class="totals__value" style="color:#475569">—</div>
            {% endif %}
        </div>
    </div>
</div>

{# ── Footer ── #}
<div class="footer">
    <span>{{ organization.name }} — Catalogue confidentiel</span>
    <span>{{ generatedAt|date('d/m/Y') }}</span>
</div>

</body>
</html>
