<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 13px;
        color: #1e293b;
        background: #fff;
        padding: 40px;
    }

    /* ── Header ── */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding-bottom: 20px;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 28px;
    }
    .header__org {
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 4px;
    }
    .header__title {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
    }
    .header__meta {
        text-align: right;
        font-size: 11px;
        color: #94a3b8;
        line-height: 1.6;
    }
    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }
    .badge--category { background: #ede9fe; color: #5b21b6; }
    .badge--ref { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; }

    /* ── Body layout ── */
    .body {
        display: flex;
        gap: 28px;
        margin-bottom: 28px;
    }
    .body__image {
        flex-shrink: 0;
        width: 200px;
        height: 200px;
        border-radius: 10px;
        overflow: hidden;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .body__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .body__image--empty {
        color: #cbd5e1;
        font-size: 40px;
    }
    .body__info { flex: 1; }

    /* ── Info list ── */
    .info-list {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 16px;
    }
    .info-list tr { border-bottom: 1px solid #f1f5f9; }
    .info-list tr:last-child { border-bottom: none; }
    .info-list td {
        padding: 7px 0;
        vertical-align: top;
        line-height: 1.5;
    }
    .info-list td:first-child {
        width: 130px;
        font-size: 11px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding-right: 12px;
    }
    .info-list td:last-child { color: #1e293b; }
    .price { font-weight: 700; font-size: 14px; }
    .price--selling { color: #4f46e5; }
    .price--positive { color: #16a34a; }
    .price--negative { color: #dc2626; }

    /* ── Tags ── */
    .tags { display: flex; flex-wrap: wrap; gap: 4px; }
    .tag {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 11px;
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    /* ── Description ── */
    .description {
        background: #f8fafc;
        border-left: 3px solid #4f46e5;
        border-radius: 0 6px 6px 0;
        padding: 12px 16px;
        margin-bottom: 28px;
        font-size: 13px;
        line-height: 1.7;
        color: #334155;
    }
    .description__title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #4f46e5;
        margin-bottom: 6px;
    }

    /* ── Totals ── */
    .totals {
        margin-top: auto;
        background: #0f172a;
        border-radius: 12px;
        padding: 20px 24px;
        color: #fff;
        page-break-inside: avoid;
    }
    .totals__title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #94a3b8;
        margin-bottom: 16px;
    }
    .totals__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }
    .totals__item {
        background: rgba(255,255,255,0.06);
        border-radius: 8px;
        padding: 14px 16px;
    }
    .totals__label {
        font-size: 11px;
        color: #94a3b8;
        margin-bottom: 6px;
        font-weight: 500;
    }
    .totals__value {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #f1f5f9;
    }
    .totals__value--positive { color: #4ade80; }
    .totals__value--negative { color: #f87171; }
    .totals__sub {
        font-size: 11px;
        color: #64748b;
        margin-top: 3px;
    }

    /* ── Footer ── */
    .footer {
        margin-top: 24px;
        padding-top: 14px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #94a3b8;
    }
</style>
</head>
<body>

{# ── Header ── #}
<div class="header">
    <div>
        <div class="header__org">{{ organization.name }}</div>
        <div class="header__title">{{ product.name }}</div>
        <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;">
            {% if product.category %}
                <span class="badge badge--category">{{ product.category.name }}</span>
            {% endif %}
            {% if product.reference %}
                <span class="badge badge--ref">{{ product.reference }}</span>
            {% endif %}
        </div>
    </div>
    <div class="header__meta">
        Fiche produit<br>
        Généré le {{ generatedAt|date('d/m/Y à H:i') }}<br>
        Mis à jour le {{ product.updatedAt|date('d/m/Y') }}
    </div>
</div>

{# ── Body ── #}
<div class="body">
    {# Image #}
    <div class="body__image{% if not imageBase64 %} body__image--empty{% endif %}">
        {% if imageBase64 %}
            <img src="data:{{ imageMime }};base64,{{ imageBase64 }}" alt="{{ product.name }}">
        {% else %}
            📷
        {% endif %}
    </div>

    {# Infos #}
    <div class="body__info">
        <table class="info-list">
            {% if product.tags|length > 0 %}
            <tr>
                <td>Tags</td>
                <td>
                    <div class="tags">
                        {% for tag in product.tags %}
                            <span class="tag">{{ tag.name }}</span>
                        {% endfor %}
                    </div>
                </td>
            </tr>
            {% endif %}
            <tr>
                <td>Stock</td>
                <td><strong>{{ product.stockQuantity }}</strong> unité{{ product.stockQuantity > 1 ? 's' : '' }}</td>
            </tr>
            {% if product.price %}
                {% if product.price.purchasePriceCents is not null %}
                <tr>
                    <td>Prix d'achat</td>
                    <td class="price">{{ (product.price.purchasePriceCents / 100)|number_format(2, ',', ' ') }} €</td>
                </tr>
                {% endif %}
                {% if product.price.sellingPriceCents is not null %}
                <tr>
                    <td>Prix de vente</td>
                    <td class="price price--selling">{{ (product.price.sellingPriceCents / 100)|number_format(2, ',', ' ') }} €</td>
                </tr>
                {% endif %}
                {% if product.price.purchasePriceCents is not null and product.price.sellingPriceCents is not null %}
                    {% set margin = product.price.sellingPriceCents - product.price.purchasePriceCents %}
                    {% set marginPct = product.price.purchasePriceCents > 0 ? ((margin / product.price.purchasePriceCents) * 100)|number_format(1, ',', ' ') : null %}
                <tr>
                    <td>Marge unitaire</td>
                    <td class="price {{ margin >= 0 ? 'price--positive' : 'price--negative' }}">
                        {{ (margin / 100)|number_format(2, ',', ' ') }} €
                        {% if marginPct is not null %}<small style="font-size:11px;font-weight:500"> ({{ marginPct }}%)</small>{% endif %}
                    </td>
                </tr>
                {% endif %}
            {% endif %}
            <tr>
                <td>Créé le</td>
                <td>{{ product.createdAt|date('d/m/Y') }}</td>
            </tr>
        </table>
    </div>
</div>

{# ── Description ── #}
{% if product.description %}
<div class="description">
    <div class="description__title">Description</div>
    {{ product.description|nl2br }}
</div>
{% endif %}

{# ── Totals ── #}
<div class="totals">
    <div class="totals__title">Récapitulatif du stock</div>
    <div class="totals__grid">

        {# Valeur d'achat totale #}
        {% if product.price and product.price.purchasePriceCents is not null %}
            {% set totalPurchase = product.stockQuantity * product.price.purchasePriceCents %}
            <div class="totals__item">
                <div class="totals__label">Valeur d'achat totale</div>
                <div class="totals__value">{{ (totalPurchase / 100)|number_format(2, ',', ' ') }} €</div>
                <div class="totals__sub">{{ product.stockQuantity }} × {{ (product.price.purchasePriceCents / 100)|number_format(2, ',', ' ') }} €</div>
            </div>
        {% else %}
            <div class="totals__item">
                <div class="totals__label">Valeur d'achat totale</div>
                <div class="totals__value" style="color:#475569;">—</div>
            </div>
        {% endif %}

        {# Revenu de vente potentiel #}
        {% if product.price and product.price.sellingPriceCents is not null %}
            {% set totalSelling = product.stockQuantity * product.price.sellingPriceCents %}
            <div class="totals__item">
                <div class="totals__label">Revenu de vente potentiel</div>
                <div class="totals__value totals__value--positive">{{ (totalSelling / 100)|number_format(2, ',', ' ') }} €</div>
                <div class="totals__sub">{{ product.stockQuantity }} × {{ (product.price.sellingPriceCents / 100)|number_format(2, ',', ' ') }} €</div>
            </div>
        {% else %}
            <div class="totals__item">
                <div class="totals__label">Revenu de vente potentiel</div>
                <div class="totals__value" style="color:#475569;">—</div>
            </div>
        {% endif %}

        {# Marge totale #}
        {% if product.price and product.price.purchasePriceCents is not null and product.price.sellingPriceCents is not null %}
            {% set totalMargin = product.stockQuantity * (product.price.sellingPriceCents - product.price.purchasePriceCents) %}
            <div class="totals__item">
                <div class="totals__label">Marge totale potentielle</div>
                <div class="totals__value {{ totalMargin >= 0 ? 'totals__value--positive' : 'totals__value--negative' }}">
                    {{ (totalMargin / 100)|number_format(2, ',', ' ') }} €
                </div>
                <div class="totals__sub">{{ product.stockQuantity }} × {{ ((product.price.sellingPriceCents - product.price.purchasePriceCents) / 100)|number_format(2, ',', ' ') }} €</div>
            </div>
        {% else %}
            <div class="totals__item">
                <div class="totals__label">Marge totale potentielle</div>
                <div class="totals__value" style="color:#475569;">—</div>
            </div>
        {% endif %}

    </div>
</div>

{# ── Footer ── #}
<div class="footer">
    <span>{{ organization.name }} — Fiche produit confidentielle</span>
    <span>{{ product.name }}{% if product.reference %} · Réf. {{ product.reference }}{% endif %}</span>
</div>

</body>
</html>
