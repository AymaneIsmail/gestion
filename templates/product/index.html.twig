{% extends 'base.html.twig' %}

{% block title %}Produits{% endblock %}

{% block content %}
<div
    data-controller="product-list modal"
    data-product-list-url-value="{{ path('app_product_index') }}"
    data-has-more="{{ hasMore ? 'true' : 'false' }}"
    data-total="{{ total }}"
>
    <div class="page-header">
        <div>
            <h1 class="page-title">Produits</h1>
            <p class="page-subtitle" data-product-list-target="count">{{ total }} produit{{ total != 1 ? 's' : '' }}</p>
        </div>
        <div class="page-header__actions">
            <div class="kebab-menu" data-controller="dropdown">
                <button
                    type="button"
                    class="kebab-menu__trigger"
                    aria-label="Actions"
                    aria-haspopup="true"
                    data-action="click->dropdown#toggle"
                >
                    <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                        <path d="M10 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4z"/>
                    </svg>
                </button>
                <div class="kebab-menu__dropdown" data-dropdown-target="menu" role="menu">
                    <button
                        type="button"
                        class="kebab-menu__item"
                        role="menuitem"
                        data-action="click->modal#open"
                    >
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM6.293 6.707a1 1 0 010-1.414l3-3a1 1 0 011.414 0l3 3a1 1 0 01-1.414 1.414L11 5.414V13a1 1 0 11-2 0V5.414L7.707 6.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Importer depuis un PDF
                    </button>
                    <a href="{{ path('app_product_export_all_pdf') }}"
                       class="kebab-menu__item"
                       target="_blank"
                       role="menuitem">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd"/>
                        </svg>
                        Exporter tout en PDF
                    </a>
                    <a href="{{ path('app_product_export_csv') }}"
                       class="kebab-menu__item"
                       role="menuitem">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                        Exporter CSV Whatnot
                    </a>
                </div>
            </div>
            <a href="{{ path('app_product_new') }}" class="btn btn--primary">
                + Nouveau produit
            </a>
        </div>
    </div>

    <div class="product-grid" data-product-list-target="grid">
        {% for product in products %}
            {{ include('product/_card.html.twig') }}
        {% endfor %}

        {% if products is empty %}
            <div class="empty-state" style="grid-column: 1 / -1;">
                <div class="empty-state__icon">📦</div>
                <h2 class="empty-state__title">Aucun produit</h2>
                <p class="empty-state__description">Commencez par créer votre premier produit.</p>
                <a href="{{ path('app_product_new') }}" class="btn btn--primary">Créer un produit</a>
            </div>
        {% endif %}
    </div>

    <div data-product-list-target="spinner" class="product-spinner">
        <span class="product-spinner__dot"></span>
        <span class="product-spinner__dot"></span>
        <span class="product-spinner__dot"></span>
    </div>

    <div data-product-list-target="sentinel" style="height: 1px;"></div>

    {# ── Modale import PDF ── #}
    <div class="modal" data-modal-target="panel" data-action="click->modal#backdropClick">
        <div class="modal__panel" data-controller="pdf-upload">
            <div class="modal__header">
                <h2 class="modal__title">Importer depuis un PDF</h2>
                <button type="button" class="modal__close" aria-label="Fermer" data-action="click->modal#close">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                </button>
            </div>

            <form
                method="post"
                action="{{ path('app_import_pdf_process') }}"
                enctype="multipart/form-data"
                data-action="submit->pdf-upload#submit"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('import-pdf') }}">

                <div class="modal__body">
                    <p class="modal__description">L'IA extraira automatiquement les produits du document.</p>

                    <input
                        type="file"
                        name="pdf"
                        id="pdf-modal"
                        accept=".pdf,application/pdf"
                        required
                        class="img-upload-input"
                        data-pdf-upload-target="input"
                        data-action="change->pdf-upload#preview"
                    >

                    <label for="pdf-modal" class="img-dropzone" data-pdf-upload-target="dropzone" data-action="click->pdf-upload#pick">
                        <div class="img-dropzone__icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                            </svg>
                        </div>
                        <span class="img-dropzone__label" data-pdf-upload-target="label">
                            Cliquez pour sélectionner un fichier PDF
                        </span>
                        <span class="img-dropzone__hint">PDF uniquement — 10 Mo max</span>
                    </label>
                </div>

                <div class="modal__footer">
                    <button type="button" class="btn btn--secondary" data-action="click->modal#close">Annuler</button>
                    <button type="submit" class="btn btn--primary" data-pdf-upload-target="submitBtn">
                        Extraire les produits
                    </button>
                </div>
            </form>

            <div class="pdf-loading-overlay" data-pdf-upload-target="overlay">
                <div class="pdf-loading-overlay__box">
                    <div class="product-spinner is-loading">
                        <span class="product-spinner__dot"></span>
                        <span class="product-spinner__dot"></span>
                        <span class="product-spinner__dot"></span>
                    </div>
                    <p class="pdf-loading-overlay__label">Analyse du PDF en cours…</p>
                    <p class="pdf-loading-overlay__hint">L'IA extrait les produits, cela peut prendre quelques secondes.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
