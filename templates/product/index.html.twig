{% extends 'base.html.twig' %}

{% block title %}Produits{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Produits</h1>
        <p class="page-subtitle">{{ products|length }} produit{{ products|length != 1 ? 's' : '' }}</p>
    </div>
    <a href="{{ path('app_product_new') }}" class="btn btn--primary">
        + Nouveau produit
    </a>
</div>

{% if products is empty %}
    <div class="empty-state">
        <div class="empty-state__icon">📦</div>
        <h2 class="empty-state__title">Aucun produit</h2>
        <p class="empty-state__description">Commencez par créer votre premier produit.</p>
        <a href="{{ path('app_product_new') }}" class="btn btn--primary">Créer un produit</a>
    </div>
{% else %}
    <div class="product-grid">
        {% for product in products %}
            <div class="product-card">
                <div class="product-card__image-wrap">
                    {% if product.images|length > 0 %}
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card__image-link">
                            <img
                                src="{{ path('app_image_serve', {id: product.images.first.id}) }}"
                                alt="{{ product.name }}"
                                class="product-card__image"
                                loading="lazy"
                            >
                        </a>
                    {% else %}
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="product-card__image-link product-card__image-link--empty">
                            <span class="product-card__no-image">📷</span>
                        </a>
                    {% endif %}
                    {% if product.price and product.price.purchasePriceCents is not null and product.price.sellingPriceCents is not null %}
                        {% set margin = product.price.sellingPriceCents - product.price.purchasePriceCents %}
                        {% set marginPct = product.price.purchasePriceCents > 0 ? ((margin / product.price.purchasePriceCents) * 100)|number_format(1, ',', ' ') : null %}
                        <span class="product-card__margin-badge margin-badge {{ margin >= 0 ? 'margin-badge--positive' : 'margin-badge--negative' }}">
                            {{ marginPct is not null ? (margin >= 0 ? '+' : '') ~ marginPct ~ '%' : (margin / 100)|number_format(2, ',', ' ') ~ ' €' }}
                        </span>
                    {% endif %}
                </div>

                <div class="product-card__body">
                    <div class="product-card__meta">
                        {% if product.category %}
                            <span class="badge badge--category">{{ product.category.name }}</span>
                        {% endif %}
                        {% if product.reference %}
                            <span class="badge badge--ref">{{ product.reference }}</span>
                        {% endif %}
                    </div>

                    <h2 class="product-card__name">
                        <a href="{{ path('app_product_show', {id: product.id}) }}">{{ product.name }}</a>
                    </h2>

                    <div class="product-card__price-row">
                        {% if product.price and product.price.sellingPriceCents %}
                            <span class="product-card__price">
                                {{ (product.price.sellingPriceCents / 100)|number_format(2, ',', ' ') }} €
                            </span>
                        {% endif %}
                        <span class="stock-badge" data-in-stock="{{ product.stockQuantity > 0 ? '1' : '0' }}">
                            {{ product.stockQuantity }}
                        </span>
                    </div>

                    {% if product.tags|length > 0 %}
                        <div class="product-card__tags">
                            {% for tag in product.tags %}
                                <span class="tag">{{ tag.name }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <div class="product-card__actions">
                    <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn--secondary btn--sm">
                        Modifier
                    </a>
                    {{ include('partials/_delete_form.html.twig', {
                        action: path('app_product_delete', {id: product.id}),
                        token_id: 'delete-product-' ~ product.id,
                    }) }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
