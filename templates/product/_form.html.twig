{{ include('partials/_form_errors.html.twig') }}

<div class="form-section">
    <h2 class="form-section__title">Informations générales</h2>
    <div class="form-grid">
        <div class="form-group form-group--full">
            {{ form_label(form.name) }}
            {{ form_widget(form.name, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <div class="form-group">
            {{ form_label(form.reference) }}
            {{ form_widget(form.reference, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.reference) }}
        </div>
        <div class="form-group">
            {{ form_label(form.category) }}
            {{ form_widget(form.category, {attr: {class: 'form-select'}}) }}
            {{ form_errors(form.category) }}
        </div>
        <div class="form-group form-group--full"
             data-controller="generate-description"
             {% if product is defined %}
             data-generate-description-url-value="{{ path('app_product_generate_description', {id: product.id}) }}"
             {% else %}
             data-generate-description-new-url-value="{{ path('app_product_generate_description_new') }}"
             {% endif %}>
            <div class="form-label-row">
                {{ form_label(form.description) }}
                <button type="button"
                        class="btn-generate-desc"
                        data-generate-description-target="button"
                        data-action="click->generate-description#generate">
                    <span data-generate-description-target="spinner" hidden>
                        <svg class="btn-generate-desc__spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v3m0 12v3M3 12h3m12 0h3m-2.636-6.364-2.122 2.122M8.757 15.243l-2.121 2.121M5.364 5.364l2.122 2.122M15.243 15.243l2.121 2.121"/>
                        </svg>
                    </span>
                    <svg class="btn-generate-desc__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.091Z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
                    </svg>
                    Générer avec l'IA
                </button>
            </div>
            <div class="ai-textarea-wrap">
                {{ form_widget(form.description, {attr: {
                    class: 'form-control',
                    'data-generate-description-target': 'textarea'
                }}) }}
                <div class="ai-overlay" data-generate-description-target="overlay" hidden>
                    <span class="ai-overlay__icon" data-generate-description-target="overlayIcon">🔍</span>
                    <span class="ai-overlay__label" data-generate-description-target="overlayLabel">Génération en cours…</span>
                </div>
            </div>
            {{ form_errors(form.description) }}
        </div>
    </div>
</div>

<div class="form-section" data-controller="tag-picker">
    <div class="form-section__title-row">
        <h2 class="form-section__title">Tags</h2>
        <span class="tag-picker-count" data-tag-picker-target="count"></span>
    </div>

    {% if form.tags|length == 0 %}
        <p class="form-hint">
            Aucun tag disponible.
            <a href="{{ path('app_tag_new') }}" target="_blank">Créer un tag →</a>
        </p>
    {% else %}
        <div class="tag-picker-grid"
             data-tag-picker-target="grid"
             data-action="change->tag-picker#toggle">
            {% for child in form.tags %}
                <div class="tag-chip-wrap">
                    {{ form_widget(child) }}
                    {{ form_label(child) }}
                </div>
            {% endfor %}
        </div>
        {{ form_errors(form.tags) }}
    {% endif %}
</div>

<div class="form-section">
    <h2 class="form-section__title">Tarification & Stock</h2>
    <div class="form-grid form-grid--2">
        <div class="form-group">
            {{ form_label(form.purchasePriceCents) }}
            <div class="input-with-unit">
                {{ form_widget(form.purchasePriceCents, {attr: {class: 'form-control'}}) }}
                <span class="input-unit">€</span>
            </div>
            {{ form_errors(form.purchasePriceCents) }}
        </div>
        <div class="form-group">
            {{ form_label(form.sellingPriceCents) }}
            <div class="input-with-unit">
                {{ form_widget(form.sellingPriceCents, {attr: {class: 'form-control'}}) }}
                <span class="input-unit">€</span>
            </div>
            {{ form_errors(form.sellingPriceCents) }}
        </div>
        <div class="form-group">
            {{ form_label(form.stockQuantity) }}
            <div class="input-with-unit">
                {{ form_widget(form.stockQuantity, {attr: {class: 'form-control'}}) }}
                <span class="input-unit">unités</span>
            </div>
            {{ form_errors(form.stockQuantity) }}
        </div>
    </div>
</div>

<div class="form-section" data-controller="image-preview">
    <div class="form-section__title-row">
        <h2 class="form-section__title">Images</h2>
        <span class="tag-picker-count" data-image-preview-target="count"></span>
    </div>

    {{- form_widget(form.images, {attr: {
        class: 'img-upload-input',
        multiple: 'multiple',
        accept: 'image/*',
        'data-image-preview-target': 'input',
        'data-action': 'change->image-preview#change'
    }}) -}}
    {{ form_errors(form.images) }}

    {# Zone de dépôt cliquable #}
    <button type="button" class="img-dropzone" data-action="click->image-preview#pick">
        <div class="img-dropzone__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 21h18M3.75 3h16.5M12 3v8m0 0l-3-3m3 3l3-3"/>
            </svg>
        </div>
        <span class="img-dropzone__label">Cliquez pour sélectionner des images</span>
        <span class="img-dropzone__hint">JPEG, PNG, WebP, GIF — 5 Mo max par image</span>
    </button>

    {# État vide #}
    <p class="img-empty" data-image-preview-target="empty">Aucune image sélectionnée.</p>

    {# Grille d'aperçus #}
    <div class="img-preview-grid" data-image-preview-target="grid"></div>
</div>
